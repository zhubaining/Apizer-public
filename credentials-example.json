{
  "version": 1,
  "connectors": {
    "deepseek-open-platform-balance": {
      "auth": {
        "authorization_bearer": "<DEEPSEEK_AUTHORIZATION_BEARER>",
        "x_app_version": "<DEEPSEEK_APP_VERSION>"
      },
      "runtime": {
        "referer": "https://platform.deepseek.com/usage",
        "user_agent": "<BROWSER_USER_AGENT>"
      }
    },
    "jike-post-engagement-stats": {
      "auth": {
        "x_jike_access_token": "<JIKE_ACCESS_TOKEN>"
      },
      "runtime": {
        "username": "<JIKE_USERNAME_OR_UID>",
        "referer": "<OPTIONAL_REFERER>",
        "user_agent": "<BROWSER_USER_AGENT>"
      }
    },
    "jike-post-manage": {
      "auth": {
        "x_jike_access_token": "<JIKE_ACCESS_TOKEN>"
      },
      "runtime": {
        "username": "<JIKE_USERNAME_OR_UID>",
        "default_topic_id": "<DEFAULT_TOPIC_ID>",
        "referer": "<OPTIONAL_REFERER>",
        "user_agent": "<BROWSER_USER_AGENT>"
      }
    },
    "wechat-web-message-manage": {
      "auth": {
        "cookie_header": "<WECHAT_WEB_COOKIE_HEADER>"
      },
      "runtime": {
        "host": "wx.qq.com",
        "push_host": "webpush.wx.qq.com",
        "uin": "<WECHAT_UIN>",
        "sid": "<WECHAT_SID>",
        "skey": "<WECHAT_SKEY>",
        "pass_ticket": "<WECHAT_PASS_TICKET>",
        "from_user_name": "<WECHAT_FROM_USER_NAME>",
        "default_to_user_name": "<WECHAT_DEFAULT_TO_USER_NAME>",
        "default_to_user_display_name": "<WECHAT_DEFAULT_TO_USER_DISPLAY_NAME>",
        "sync_check_key": "<WECHAT_SYNC_CHECK_KEY>",
        "sync_key": {
          "Count": "<SYNC_KEY_COUNT>",
          "List": [
            { "Key": "<KEY_1>", "Val": "<VAL_1>" },
            { "Key": "<KEY_2>", "Val": "<VAL_2>" }
          ]
        },
        "referer": "https://wx.qq.com/",
        "user_agent": "<BROWSER_USER_AGENT>"
      }
    }
  }
}
